# PORT=8081 (set in docker-compose)
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=10

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8080

# ---- Kafka ----
KAFKA_BROKERS=localhost:9093
