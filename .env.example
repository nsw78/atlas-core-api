# ==============================================================
# Atlas Core API - Environment Configuration
# Copy this file to .env and adjust values for your environment
# ==============================================================

# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=false

# ---- Secrets (MUST CHANGE IN PRODUCTION) ----
JWT_SECRET=change-me-in-production-use-64-char-random-string
POSTGRES_PASSWORD=atlas_dev

# ---- API Gateway ----
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s
SERVER_GRACEFUL_SHUTDOWN=true

# ---- JWT / Auth ----
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=168h
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15m
MFA_REQUIRED=false
MFA_ISSUER=ATLAS
SESSION_TIMEOUT=24h
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true

# ---- Database (PostgreSQL) ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=atlas
DATABASE_PASSWORD=atlas_dev
DATABASE_NAME=atlas
DATABASE_SSLMODE=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MIN_CONNECTIONS=5
DATABASE_CONN_MAX_LIFETIME=0
DATABASE_CONN_MAX_IDLE_TIME=10m
DATABASE_LOG_QUERIES=false
# Full URL (used by IAM service and docker-compose)
DATABASE_URL=postgres://atlas:atlas_dev@localhost:5437/atlas?sslmode=disable

# ---- Cache / Redis ----
CACHE_ENABLED=true
CACHE_TYPE=redis
CACHE_TTL=1h
REDIS_URL=redis://localhost:6392/0
CACHE_MAX_SIZE=1000
CACHE_EVICTION_POLICY=lru

# ---- CORS ----
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3004,https://localhost:3004
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_EXPOSED_HEADERS=X-Total-Count,X-Page-Number
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=50
RATE_LIMIT_CLEANUP_INTERVAL=1m

# ---- Security / TLS ----
TLS_ENABLED=false
TLS_CERT_FILE=/etc/ssl/certs/cert.pem
TLS_KEY_FILE=/etc/ssl/private/key.pem
HTTPS=false
CSRF_ENABLED=true
XSS_PROTECTION=true
CONTENT_SECURITY_POLICY=default-src 'self'
ALLOWED_ORIGINS=http://localhost:3004

# ---- Observability / Tracing ----
TRACING_ENABLED=false
JAEGER_ENDPOINT=localhost:14250
TRACING_SAMPLING_FRACTION=0.1

# ---- Metrics (Prometheus) ----
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# ---- Service Registry (override per-service URLs) ----
# SERVICE_IAM_SERVICE_URL=http://iam-service:8081
# SERVICE_RISK_ASSESSMENT_URL=http://risk-assessment:8082
# SERVICE_NEWS_AGGREGATOR_URL=http://news-aggregator:8083
