      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(auth_requests_total{job=\"api-gateway\",result=\"success\"}[5m]))",
          "legendFormat": "Auth Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(auth_requests_total{job=\"api-gateway\",result=\"failure\"}[5m]))",
          "legendFormat": "Auth Failure",
          "refId": "B"
        },
        {
          "expr": "sum(rate(auth_requests_total{job=\"api-gateway\",result=\"expired\"}[5m]))",
          "legendFormat": "Token Expired",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Rate Limiting Hits",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rate_limit_exceeded_total{job=\"api-gateway\"}[5m])) by (client_id)",
          "legendFormat": "{{ client_id }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rate_limit_allowed_total{job=\"api-gateway\"}[5m]))",
          "legendFormat": "Allowed",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
